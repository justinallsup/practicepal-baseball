{
  "expo": {
    "name": "PracticePal Baseball",
    "slug": "practicepal-baseball",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.practicepal.baseball",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "package": "com.practicepal.baseball"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "practicepal",
    "extra": {
      "eas": {
        "projectId": "practicepal-baseball"
      }
    }
  }
}
