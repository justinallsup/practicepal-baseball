{
  "expo": {
    "name": "PracticePal Baseball",
    "slug": "practicepal-baseball",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.practicepal.baseball",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "We'll remind you to log practice and keep your streak alive."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "package": "com.practicepal.baseball"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1e40af",
          "sounds": []
        }
      ]
    ],
    "scheme": "practicepal",
    "extra": {
      "eas": {
        "projectId": "practicepal-baseball"
      }
    }
  }
}
